PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
DOWNLOAD_SIGNING_SECRET=replace-with-32-byte-hex-string

# Postgres connection. In production this points at RDS; locally the
# docker-compose postgres service.
DATABASE_URL=postgres://mike:mike@localhost:5432/mike

# AWS region. Bedrock uses BEDROCK_REGION if set, otherwise AWS_REGION.
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1

# Cognito. In prod, set USER_POOL_ID / CLIENT_ID from the real user pool and
# leave COGNITO_JWKS_URI / COGNITO_ENDPOINT unset (the SDK derives them).
# For local cognito-local, point JWKS_URI at the container.
COGNITO_USER_POOL_ID=us-east-1_localDev01
COGNITO_CLIENT_ID=local-client-id
COGNITO_JWKS_URI=http://localhost:9229/us-east-1_localDev01/.well-known/jwks.json
COGNITO_ENDPOINT=http://localhost:9229

# S3 / MinIO. In prod, set S3_BUCKET_NAME and leave the rest unset; the ECS
# task role provides credentials.
S3_BUCKET_NAME=mike
S3_ENDPOINT_URL=http://localhost:9100
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Direct LLM providers (Claude is on Bedrock and uses IAM, no key needed).
# These can also be supplied per-user from the Account > Models page; the
# server-side env vars take precedence when set.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Required for encrypting per-user provider API keys at rest.
USER_API_KEYS_ENCRYPTION_SECRET=replace-with-long-random-string

# Rate limits (optional overrides).
# RATE_LIMIT_GENERAL_WINDOW_MINUTES=15
# RATE_LIMIT_GENERAL_MAX=300
# RATE_LIMIT_CHAT_WINDOW_MINUTES=15
# RATE_LIMIT_CHAT_MAX=30
# RATE_LIMIT_CHAT_CREATE_WINDOW_MINUTES=15
# RATE_LIMIT_CHAT_CREATE_MAX=60
# RATE_LIMIT_UPLOAD_WINDOW_HOURS=1
# RATE_LIMIT_UPLOAD_MAX=50
# TRUST_PROXY_HOPS=1
