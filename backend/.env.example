# Mike Atlas — backend environment template
# Copy to backend/.env and run `make bootstrap` to generate local secrets.
# NEVER commit backend/.env to Git.

NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Required: HMAC key used to sign /download/:token URLs.
# Generated automatically by scripts/generate-local-secrets.sh.
DOWNLOAD_SIGNING_SECRET=[GENERATED_BY_BOOTSTRAP]

# Required: Supabase project URL and service-role key.
# Local values are injected by `make bootstrap` from `npx supabase@latest status`.
SUPABASE_URL=http://localhost:54321
SUPABASE_SECRET_KEY=[GENERATED_BY_BOOTSTRAP]

# Required: S3-compatible storage credentials.
# For local development with MinIO, bootstrap uses the local container values.
# Prefer S3_* variables; R2_* are kept as legacy fallback for upstream compatibility.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=mike-documents
S3_REGION=us-east-1

# Legacy R2 variables (optional; used only if S3_* are absent).
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Optional: LLM provider keys. Leave all unset to run the app without chat.
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: transactional email provider. SES will replace Resend in production.
RESEND_API_KEY=

# Required: master secret used to encrypt per-user provider API keys.
USER_API_KEYS_ENCRYPTION_SECRET=[GENERATED_BY_BOOTSTRAP]

# Optional: CourtListener token. Leave empty in local/Atlas environments.
COURTLISTENER_API_TOKEN=

# Optional / DANGEROUS: raw LLM stream logging.
# Never enable in production or with real documents. Defaults to disabled.
LOG_RAW_LLM_STREAM=false
RAW_LLM_STREAM_LOG_DIR=

# Optional: override LibreOffice binary path.
SOFFICE_BINARY_PATH=
LIBREOFFICE_BINARY_PATH=
LIBRE_OFFICE_EXE=
