{
  "name": "mike-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.787.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.787.0",
    "@aws-sdk/client-s3": "^3.787.0",
    "@aws-sdk/s3-request-presigner": "^3.787.0",
    "@google/genai": "^1.50.1",
    "aws-jwt-verify": "^5.0.0",
    "cors": "^2.8.5",
    "docx": "^9.5.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "fast-diff": "^1.3.0",
    "fast-xml-parser": "^5.7.1",
    "helmet": "^8.1.0",
    "jszip": "^3.10.1",
    "libreoffice-convert": "^1.6.0",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.2",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.18.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.20.0"
  },
  "license": "AGPL-3.0-only"
}
