# Mike Atlas — frontend public environment template
# Copy to frontend/.env.local and run `make bootstrap` to fill Supabase keys.
# NEVER commit frontend/.env.local to Git.

# Public Supabase URL and anon/public key.
# Local values are injected by `make bootstrap` from `npx supabase@latest status`.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=[GENERATED_BY_BOOTSTRAP]

# Public API base URL for the Mike backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
