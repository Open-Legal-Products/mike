# Root .env used by docker-compose. Copy to .env and edit as needed.
# Most values can stay at the defaults for local dev.
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_localDev01
COGNITO_CLIENT_ID=local-client-id
S3_BUCKET_NAME=mike
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
DOWNLOAD_SIGNING_SECRET=dev-replace-with-real-32-byte-hex
USER_API_KEYS_ENCRYPTION_SECRET=dev-replace-with-real-long-random-string
GEMINI_API_KEY=
OPENAI_API_KEY=
